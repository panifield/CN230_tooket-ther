# Copy to .env and adjust. Sync driver for SQLAlchemy + Alembic (psycopg3).
DATABASE_URL=postgresql+psycopg://tooket:tooket@localhost:5432/tooket_ther

# Queue (Phase 1+) — required for /api/v1/concerts/.../queue/*
REDIS_URL=redis://localhost:6379/0

# Comma-separated browser origins for CORS (dev)
CORS_ORIGINS=

# App
APP_NAME=Tooket-ther API
DEBUG=false

# JWT (change JWT_SECRET_KEY in production)
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ACCESS_EXPIRE_MINUTES=10080
JWT_ADMISSION_EXPIRE_MINUTES=10

# OAuth — Line / Meta developer consoles; redirect_uri must match exactly.
OAUTH_LINE_CHANNEL_ID=
OAUTH_LINE_CHANNEL_SECRET=
OAUTH_FACEBOOK_APP_ID=
OAUTH_FACEBOOK_APP_SECRET=
OAUTH_REDIRECT_URI_LINE=http://localhost:3000/auth/line/callback
OAUTH_REDIRECT_URI_FACEBOOK=http://localhost:3000/auth/facebook/callback
